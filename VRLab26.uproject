{
	"FileVersion": 3,
	"EngineAssociation": "5.5",
	"Category": "Games",
	"Description": "VRLab26 Hackathon — VR game for Meta Quest 2/3 via Unreal Engine and OpenXR.",
	"Modules": [
		{
			"Name": "VRLab26",
